(* Beginning of Notebook Content *)
Notebook[{

Cell[CellGroupData[{
Cell["\<\
The finite difference method for the viscous Burgers equation\
\>", "Title",
 CellChangeTimes->{{3.9907976947844486`*^9, 
  3.990797710544386*^9}},ExpressionUUID->"6a47e1d0-39b0-ad4e-84bc-\
53368f7ffcda"],

Cell["\<\
Explicit finite differences on a periodic, validated against the exact \
solution (using Cole-Hopf transformation)\
\>", "Subtitle",
 CellChangeTimes->{{3.990797720257509*^9, 
  3.9907977543631496`*^9}},ExpressionUUID->"ccece35a-ffa0-ff4e-bd1b-\
41c4d13a90b2"],

Cell[TextData[{
 "Ruben Ranval \n",
 StyleBox["ruben.ranval@polytechnique.edu",
  FontSize->12,
  FontSlant->"Italic",
  FontColor->RGBColor[
   0.5019607843137255, 0.5019607843137255, 0.5019607843137255]]
}], "Text",
 CellChangeTimes->{{3.9907967390317307`*^9, 3.990796768677511*^9}, 
   3.990797763502266*^9},ExpressionUUID->"db598e80-2cdb-7243-9986-\
d2fd87c45762"],

Cell[CellGroupData[{

Cell["Introduction", "Section",
 CellChangeTimes->{{3.990797776459633*^9, 
  3.990797780627636*^9}},ExpressionUUID->"c6aaa471-85cf-1c49-b125-\
ecad193b4077"],

Cell["\<\
The Burgers equation is a simple canonical one-dimensional model in which a \
convective nonlinearity competes with viscous diffusion. The reason, I\
\[CloseCurlyQuote]m using it is that it\[CloseCurlyQuote]s the simplest \
equation that keeps the quadratic nonlinearity of Navier Stokes while \
remaining exactly solvable (which makes it an ideal benchmark for numerical \
methods).\
\>", "Text",
 CellChangeTimes->{{3.9907977878074703`*^9, 
  3.9907979129534626`*^9}},ExpressionUUID->"f89ddd70-e786-be49-9f61-\
6362abf776b2"],

Cell["\<\
In this notebook, I will solve the Burgers equation on a periodic domain with \
a fully explicit FD scheme, and thn validate the result againt the exact \
solution obtained through the Cole-Hopf transformation.\
\>", "Text",
 CellChangeTimes->{{3.9907979232056484`*^9, 
  3.9907979768738766`*^9}},ExpressionUUID->"e0620901-2b6f-e240-bcb2-\
ea75c44cde08"]
}, Open  ]],

Cell[CellGroupData[{

Cell["The Mathematical problem", "Section",
 CellChangeTimes->{{3.990798005227129*^9, 
  3.9907980117440586`*^9}},ExpressionUUID->"deed529e-0bff-624d-831d-\
c79d5433bbb0"],

Cell[CellGroupData[{

Cell["Governing equation", "Subsection",
 CellChangeTimes->{{3.990798041297617*^9, 
  3.990798046694668*^9}},ExpressionUUID->"1c6a3c86-4ec3-3f4b-91dc-\
9b03472bb4cd"],

Cell["We want to solve", "Text",
 CellChangeTimes->{{3.9907980573542233`*^9, 
  3.9907980608164024`*^9}},ExpressionUUID->"c415bbc0-9dfe-1446-b5d3-\
ef245cfda094"],

Cell[BoxData[
 TemplateBox[<|"boxes" -> FormBox[
     RowBox[{
       FractionBox[
        RowBox[{"\[PartialD]", 
          StyleBox["u", "TI"]}], 
        RowBox[{"\[PartialD]", 
          StyleBox["t", "TI"]}]], "+", 
       StyleBox["u", "TI"], 
       FractionBox[
        RowBox[{"\[PartialD]", 
          StyleBox["u", "TI"]}], 
        RowBox[{"\[PartialD]", 
          StyleBox["x", "TI"]}]], "\[LongEqual]", "\[Nu]", 
       FractionBox[
        RowBox[{
          SuperscriptBox["\[PartialD]", "2"], 
          StyleBox["u", "TI"]}], 
        SuperscriptBox["\[Null]", "2"]], "\[ForAll]", 
       StyleBox["x", "TI"], "\[Element]", 
       RowBox[{"[", 
         RowBox[{"0", ",", "2", "\[Pi]"}], "]"}], 
       StyleBox["t", "TI"], "\[Element]", 
       RowBox[{"[", 
         RowBox[{"0", ",", "2"}], "]"}]}], TraditionalForm], "errors" -> {}, 
   "input" -> 
   "\\frac{\\partial u}{\\partial t}+u\\frac{\\partial u}{\\partial x} = \\nu \
\\frac{\\partial^2 u}{\\partialx^2} \\space \\forall x \\in [0, 2\\pi] \
\\space t \\in [0, 2]", "state" -> "Boxes"|>,
  "TeXAssistantTemplate"]], "Text",
 CellChangeTimes->{
  3.9907980671469975`*^9, {3.9907984319716988`*^9, 3.9907984355421124`*^9}},
 TextAlignment->Center,
 Background->RGBColor[
  0.14, 0.8, 0.14, 
   0.33],ExpressionUUID->"0e2b9ecf-9292-ab45-9036-b6132aa8ed74"],

Cell[TextData[{
 "with periodic BCs and initial conditions ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["u", "TI"], 
         RowBox[{"(", 
           RowBox[{"0", ",", 
             StyleBox["x", "TI"]}], ")"}], "\[LongEqual]", "sin", 
         RowBox[{"(", 
           StyleBox["x", "TI"], ")"}]}], TraditionalForm], "errors" -> {}, 
     "input" -> "u(0,x) = \\sin (x)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d71b4fa5-2606-d146-934a-7eaa77ac7698"],
 ". The advection term is taken in conservative form, ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["u", "TI"], 
         FractionBox[
          RowBox[{"\[PartialD]", 
            StyleBox["u", "TI"]}], 
          RowBox[{"\[PartialD]", 
            StyleBox["x", "TI"]}]], "\[LongEqual]", 
         FractionBox["\[PartialD]", 
          RowBox[{"\[PartialD]", 
            StyleBox["x", "TI"]}]], 
         RowBox[{"(", 
           FractionBox[
            SuperscriptBox[
             StyleBox["u", "TI"], "2"], "2"], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "u\\frac{\\partial u}{\\partial x} = \\frac{\\partial}{\\partial \
x}(\\frac{u^2}{2})", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "759823e0-ed89-ff40-9da8-53fdc239f7df"],
 ", which is the form used for the discretization below. The constant ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Nu]", ">", "0"}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\nu > 0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "35a917f9-3913-3f46-9376-a3881877b895"],
 " is the kinematic viscosity."
}], "Text",
 CellChangeTimes->{{3.99079826280418*^9, 
  3.99079841320912*^9}},ExpressionUUID->"77fa72a9-aa46-964d-9039-\
c0b8384038eb"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Physical behavior", "Subsection",
 CellChangeTimes->{{3.990798467272669*^9, 
  3.990798470931822*^9}},ExpressionUUID->"f53fdca8-23d2-f943-bc80-\
d55e6bb672f7"],

Cell["\<\
Two mechanisms compete: the nonlinear term that steepens the profile, and for \
small \\nu tends to form a shock, while diffusion smooths gradients and \
spreads the solution. Their balance is of course measured by the Reynolds \
number. With \\nu = 0.5 (the default value of this notebook) the run is \
strongly diffusive: the initinal sine flattens and decays without forming a \
sharp front (as the results of the simulation will confirm).\
\>", "Text",
 CellChangeTimes->{{3.9907984811725845`*^9, 
  3.990798625703861*^9}},ExpressionUUID->"4398975e-1dc9-c14c-9613-\
c06720805236"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Numerical scheme", "Section",
 CellChangeTimes->{{3.990798650866766*^9, 
  3.9907986564517174`*^9}},ExpressionUUID->"e9d2aa6c-afb4-c043-ac1e-\
f77436bd612a"],

Cell[CellGroupData[{

Cell["Spatial discretization", "Subsection",
 CellChangeTimes->{{3.990798923934271*^9, 
  3.9907989285538406`*^9}},ExpressionUUID->"bfaa175a-c3c0-b74b-a1f6-\
8fd328d18f3f"],

Cell[TextData[{
 "Space is discretized on a uniform periodic grid of N\:2080 points with \
spacing ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["d", "TI"], 
         StyleBox["x", "TI"], "\[LongEqual]", 
         FractionBox[
          RowBox[{"2", "\[Pi]"}], 
          SubscriptBox[
           StyleBox["N", "TI"], "0"]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "dx = \\frac{2 \\pi}{N_0}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "4785c331-a919-1f45-9b39-440e823f1bb6"],
 ". Writing u\:2c7c for the value at node j, both spatial terms use second - \
order central differences :"
}], "Text",
 CellChangeTimes->{{3.9907989365259113`*^9, 
  3.9907989839115467`*^9}},ExpressionUUID->"5f6df910-7eb1-9644-b23c-\
8e6bc1c5e9dd"],

Cell[TextData[{
 "for the advection term: ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox["\[PartialD]", 
          RowBox[{"\[PartialD]", 
            StyleBox["x", "TI"]}]], 
         RowBox[{"(", 
           FractionBox[
            SuperscriptBox[
             StyleBox["u", "TI"], "2"], "2"], ")"}], "\[TildeTilde]", 
         FractionBox[
          RowBox[{
            SubsuperscriptBox[
             StyleBox["u", "TI"], 
             RowBox[{
               StyleBox["j", "TI"], "+", "1"}], "2"], "-", 
            SubsuperscriptBox[
             StyleBox["u", "TI"], 
             RowBox[{
               StyleBox["j", "TI"], "-", "1"}], "2"]}], 
          RowBox[{"4", 
            StyleBox["d", "TI"], 
            StyleBox["x", "TI"]}]], "\[LongEqual]", 
         StyleBox["a", "TI"], 
         StyleBox["d", "TI"], 
         StyleBox["v", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\frac{\\partial}{\\partial x}(\\frac{u^2}{2}) \\approx \
\\frac{u_{j+1}^2-u_{j-1}^2}{4dx} = adv", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "546bb2c1-9035-6d4b-8f1a-aaade981ad2e"]
}], "Item",
 CellChangeTimes->{{3.9907990152721233`*^9, 3.9907990568900986`*^9}, {
  3.9907992795151176`*^9, 
  3.9907993564251842`*^9}},ExpressionUUID->"08f5911c-b5db-574f-affe-\
af5f7814d455"],

Cell[TextData[{
 "for the diffusion term: ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Nu]", 
         FractionBox[
          RowBox[{
            SuperscriptBox["\[PartialD]", "2"], 
            StyleBox["u", "TI"]}], 
          RowBox[{"\[PartialD]", 
            SuperscriptBox[
             StyleBox["x", "TI"], "2"]}]], "\[TildeTilde]", "\[Nu]", 
         FractionBox[
          RowBox[{
            SubscriptBox[
             StyleBox["u", "TI"], 
             RowBox[{
               StyleBox["j", "TI"], "+", "1"}]], "-", "2", 
            SubscriptBox[
             StyleBox["u", "TI"], 
             StyleBox["j", "TI"]], "+", 
            SubscriptBox[
             StyleBox["u", "TI"], 
             RowBox[{
               StyleBox["j", "TI"], "-", "1"}]]}], 
          RowBox[{
            StyleBox["d", "TI"], 
            SuperscriptBox[
             StyleBox["x", "TI"], "2"]}]], "\[LongEqual]", 
         StyleBox["d", "TI"], 
         StyleBox["i", "TI"], 
         StyleBox["f", "TI"], 
         StyleBox["f", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\nu \\frac{\\partial^2 u}{\\partial x^2} \\approx \\nu \
\\frac{u_{j+1}-2u_j+u_{j-1}}{dx^2} = diff", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "dd046951-f4f0-9d4a-adae-f259c917dfb7"]
}], "Item",
 CellChangeTimes->{{3.9907990152721233`*^9, 3.9907990568900986`*^9}, {
  3.9907992795151176`*^9, 
  3.990799418937542*^9}},ExpressionUUID->"03ca35f2-dba0-c545-b42d-\
1d4a501bc340"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Time integration and stability", "Subsection",
 CellChangeTimes->{{3.9907994457719173`*^9, 
  3.990799452457985*^9}},ExpressionUUID->"33e7b50f-83f8-c049-8d39-\
0784e1146e72"],

Cell[TextData[{
 "Time advances with explicit (forward) Euler, giving the classic foward time \
central space update: ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox[
          StyleBox["u", "TI"], 
          StyleBox["j", "TI"], 
          RowBox[{
            StyleBox["n", "TI"], "+", "1"}]], "\[LongEqual]", 
         SubsuperscriptBox[
          StyleBox["u", "TI"], 
          StyleBox["j", "TI"], 
          StyleBox["n", "TI"]], "-", 
         StyleBox["d", "TI"], 
         StyleBox["t", "TI"], ".", 
         StyleBox["a", "TI"], 
         StyleBox["d", "TI"], 
         StyleBox["v", "TI"], "+", 
         StyleBox["d", "TI"], 
         StyleBox["t", "TI"], ".", 
         StyleBox["d", "TI"], 
         StyleBox["i", "TI"], 
         StyleBox["f", "TI"], 
         StyleBox["f", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "u_j^{n+1} = u_j^n - dt.adv + dt.diff", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f69596bc-d761-524e-9aba-b84eca34085e"],
 ".\nFTCS is only conditionally stable. A Von Neumann analysis od the \
linearized equation gives the following amplification factor: ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"|", 
         StyleBox["G", "TI"], 
         RowBox[{"(", "\[Theta]", ")"}], 
         SuperscriptBox["|", "2"], "\[LongEqual]", 
         SuperscriptBox[
          RowBox[{"(", 
            RowBox[{"1", "-", "2", 
              StyleBox["d", "TI"], 
              RowBox[{"(", 
                RowBox[{"1", "-", "cos", 
                  RowBox[{"(", "\[Theta]", ")"}]}], ")"}]}], ")"}], "2"], "+", 
         SuperscriptBox[
          RowBox[{"(", 
            RowBox[{
              StyleBox["C", "TI"], "sin", 
              RowBox[{"(", "\[Theta]", ")"}]}], ")"}], "2"]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "|G(\\theta)|^2 = (1 - 2d(1-\\cos (\\theta)))^2 + (C\\sin (\\theta))^2", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "4fd6449e-9807-364f-9a9b-b60811ca4414"],
 ",    with ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["d", "TI"], "\[LongEqual]", "\[Nu]", 
         FractionBox[
          RowBox[{
            StyleBox["d", FontSlant -> "Plain"], 
            StyleBox["t", "TI"]}], 
          RowBox[{
            StyleBox["d", FontSlant -> "Plain"], 
            SuperscriptBox[
             StyleBox["x", "TI"], "2"]}]]}], TraditionalForm], "errors" -> {},
      "input" -> "d = \\nu \\frac{\\mathrm{d} t}{\\mathrm{d} x^2}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "cb103dc3-d9fb-364f-8b32-bb7b8ed8d671"],
 ", and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["C", "TI"], "\[LongEqual]", 
         StyleBox["a", "TI"], 
         FractionBox[
          RowBox[{
            StyleBox["d", FontSlant -> "Plain"], 
            StyleBox["t", "TI"]}], 
          RowBox[{
            StyleBox["d", FontSlant -> "Plain"], 
            StyleBox["x", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "C = a \\frac{\\mathrm {d} t}{\\mathrm{d} x}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6b2ba842-50de-6b41-8c7b-28d0dbabe563"],
 " with ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["a", "TI"], TraditionalForm], "errors" -> {}, "input" -> "a", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a6bedf82-3c72-2042-9a0e-4ebad223008f"],
 " the local wave speed."
}], "Text",
 CellChangeTimes->{{3.990799474842367*^9, 3.9907995276573772`*^9}, {
  3.9907995582216415`*^9, 3.9907996446601944`*^9}, {3.9908505128736477`*^9, 
  3.9908506550862617`*^9}, {3.9908507071361904`*^9, 
  3.990850896430662*^9}},ExpressionUUID->"0a698f40-c1a5-bc43-a3c7-\
69f7f304cc82"],

Cell[TextData[{
 "Stability (",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"|", 
         StyleBox["G", "TI"], "|", "\[LessEqual]", "1"}], TraditionalForm], 
     "errors" -> {}, "input" -> "|G| \\leq 1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9bf03bfb-4de6-c140-bdcc-9c08f2346fba"],
 " for every mode ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[Theta]", TraditionalForm], "errors" -> {}, "input" -> 
     "\\theta", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "63cca457-30ee-0842-adcf-7e72db3e9263"],
 ") requires both ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"2", 
         StyleBox["d", "TI"], "\[LessEqual]", "1"}], TraditionalForm], 
     "errors" -> {}, "input" -> "2 d \\leq 1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2afa2baa-9230-0b45-9bf9-69ddd1b3652f"],
 " and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["C", "TI"], "2"], "\[LessEqual]", "2", 
         StyleBox["d", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "C^2 \\leq 2 d", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ec461e27-ddd2-4f49-92b4-e656cc01ea9f"],
 ". The step is therefore chosen as ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["d", FontSlant -> "Plain"], 
         StyleBox["t", "TI"], "\[LongEqual]", 
         StyleBox["m", "TI"], 
         StyleBox["i", "TI"], 
         StyleBox["n", "TI"], 
         RowBox[{"(", 
           RowBox[{"0.2", 
             FractionBox[
              RowBox[{
                StyleBox["d", FontSlant -> "Plain"], 
                SuperscriptBox[
                 StyleBox["x", "TI"], "2"]}], "\[Nu]"], ",", "0.3", 
             FractionBox[
              RowBox[{
                StyleBox["d", FontSlant -> "Plain"], 
                StyleBox["x", "TI"]}], 
              StyleBox["A", "TI"]]}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\mathrm{d}t = min (0.2 \\frac{\\mathrm{d}x^2}{\\nu}, 0.3 \
\\frac{\\mathrm{d}x}{A})", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d43cc1db-d3fe-3f4e-83a7-998fc2ccbe7f"],
 " : the first term enforces the diffusion limit, the second the advective \
CFL limit (both with a safety factor)."
}], "Text",
 CellChangeTimes->{{3.990850873251398*^9, 3.9908509101040897`*^9}, {
  3.990850955693634*^9, 
  3.990851069654768*^9}},ExpressionUUID->"9e338c8b-0200-d34f-b273-\
ed42ad1e1729"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["The actual implementation!", "Section",
 CellChangeTimes->{{3.9908511022257137`*^9, 
  3.990851109658373*^9}},ExpressionUUID->"da2d144f-8c89-c749-881d-\
91531a50e80e"],

Cell[CellGroupData[{

Cell["Setup: parameters and grid", "Subsection",
 CellChangeTimes->{{3.9908511202408314`*^9, 
  3.9908511294211197`*^9}},ExpressionUUID->"2e487252-475f-fb41-81b3-\
d85108c6c570"],

Cell[TextData[{
 "We fix the domain, the physical parameters and the grid . N\:2080 is \
entered as a real number (256.0), this forces every downstream quantity to \
machine-precision arithmetic and prevents an exact symbolic ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[Pi]", TraditionalForm], "errors" -> {}, "input" -> 
     "\\pi ", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5086b9ae-ffff-1046-b23a-16fac17f429a"],
 " from being dragged through the time loop, which would make the run explode \
in symbolic size."
}], "Text",
 CellChangeTimes->{{3.990851146127817*^9, 
  3.990851181304617*^9}},ExpressionUUID->"96990122-5c28-2947-965b-\
2b052d5ef69b"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"L", " ", "=", " ", 
    RowBox[{"2", "*", "Pi"}]}], ";"}], "        ", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"length", " ", "of", " ", "the", " ", "domain"}], ",", " ", 
    RowBox[{"chose", " ", "2", "pi", " ", "since", " ", 
     RowBox[{"it", "'"}], "s", " ", "a", " ", "sine"}]}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"N0", " ", "=", " ", "256.0"}], ";"}], "     ", 
  RowBox[{"(*", 
   RowBox[{"nbr", " ", "of", " ", "grid", " ", "points"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"dx", " ", "=", " ", 
    FractionBox["L", "N0"]}], ";"}], "          ", 
  RowBox[{"(*", 
   RowBox[{"grid", " ", "spacing"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Nu]", " ", "=", " ", "0.5"}], ";"}], "            ", 
  RowBox[{"(*", 
   RowBox[{"kinematic", " ", "viscosity"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"A", " ", "=", " ", "1.0"}], ";"}], "            ", 
  RowBox[{"(*", 
   RowBox[{"characteristic", " ", "wave", " ", "speed"}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.990851193175316*^9, 3.9908512693357525`*^9}, {
  3.990851332916113*^9, 3.9908513381650524`*^9}, {3.9908517458038807`*^9, 
  3.9908517481684265`*^9}},ExpressionUUID->"cfac954a-9c2e-e04a-872f-\
09df0e718e90"],

Cell["\<\
Now the two CFL limits we discussed in the previous section (with their \
safety factors):\
\>", "Text",
 CellChangeTimes->{{3.9908512835943527`*^9, 3.990851313308445*^9}, {
  3.9908514006117287`*^9, 
  3.990851400927351*^9}},ExpressionUUID->"f00783d9-4dbe-2e40-8ddc-\
d2c8245eb79d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"dt", " ", "=", " ", 
   RowBox[{"Min", "[", 
    RowBox[{
     RowBox[{"0.2", "*", 
      FractionBox[
       SuperscriptBox["dx", "2"], "\[Nu]"]}], ",", " ", 
     RowBox[{"0.3", "*", 
      FractionBox["dx", "A"]}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9908513264072933`*^9, 3.9908513678784904`*^9}},
 CellLabel->
  "In[186]:=",ExpressionUUID->"d35f88be-45d8-7a4b-9193-212b33719fd9"],

Cell["Now let's generate the timesteps and the initial conditions:", "Text",
 CellChangeTimes->{{3.9908513756605854`*^9, 
  3.99085140286598*^9}},ExpressionUUID->"06fd2ab7-1519-8946-ae64-\
b3e20103daac"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"tFinal", " ", "=", " ", "2.0"}], ";"}], "                  "}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"instants", " ", "=", " ", 
    RowBox[{"Floor", "[", 
     FractionBox["tFinal", "dt"], "]"}]}], ";"}], " "}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"xCoords", " ", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"i", "*", "dx"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"i", ",", " ", "0", ",", " ", 
       RowBox[{"N0", "-", "1"}]}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"initU", " ", "=", " ", 
   RowBox[{"Sin", "@", "xCoords"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.9908514118878784`*^9, 3.990851471936201*^9}},
 CellLabel->
  "In[187]:=",ExpressionUUID->"1b37402d-05f5-d447-8e1d-1bf44a64c632"]
}, Open  ]],

Cell[CellGroupData[{

Cell["The time-stepping \
\[OpenCurlyDoubleQuote]kernel\[CloseCurlyDoubleQuote]", "Subsection",
 CellChangeTimes->{{3.9908515098440723`*^9, 
  3.9908515164826717`*^9}},ExpressionUUID->"b29c5630-4dd6-a342-bda4-\
91933e204d92"],

Cell[TextData[{
 StyleBox["stepBurgers",
  FontSlant->"Italic"],
 " advances the whole field by one time step. It is written as a pure \
function of the state vector so it can be iterated cleanly. ",
 StyleBox["uR ",
  FontSlant->"Italic"],
 "and",
 StyleBox[" uL",
  FontSlant->"Italic"],
 " represent the right/left neighbors via array rotation."
}], "Text",
 CellChangeTimes->{{3.9908515648626957`*^9, 
  3.9908515890272694`*^9}},ExpressionUUID->"794dc692-01c5-6e43-9653-\
913816ef543b"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"stepBurgers", "[", 
    RowBox[{"u_", ",", " ", "\[Nu]_", ",", " ", "dt_", ",", " ", "dx_"}], 
    "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"uL", ",", " ", "uR", ",", " ", "adv", ",", " ", "diff"}], 
      "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"uR", " ", "=", " ", 
       RowBox[{"RotateLeft", "[", 
        RowBox[{"u", ",", "1"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"uL", " ", "=", " ", 
       RowBox[{"RotateRight", "[", 
        RowBox[{"u", ",", " ", "1"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"adv", "=", " ", 
       FractionBox[
        RowBox[{
         SuperscriptBox["uR", "2"], "-", 
         SuperscriptBox["uL", "2"]}], 
        RowBox[{"4", "dx"}]]}], ";", "\[IndentingNewLine]", 
      RowBox[{"diff", " ", "=", " ", 
       RowBox[{"\[Nu]", "*", 
        FractionBox[
         RowBox[{"(", 
          RowBox[{"uR", "-", 
           RowBox[{"2", "u"}], "+", "uL"}], ")"}], 
         SuperscriptBox["dx", "2"]]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"u", " ", "-", " ", 
       RowBox[{"dt", "*", "adv"}], " ", "+", " ", 
       RowBox[{"dt", "*", "diff"}]}]}]}], "\[IndentingNewLine]", "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.990851686271776*^9, 3.9908517191807823`*^9}, {
  3.9908517554849415`*^9, 3.9908519277693424`*^9}},
 CellLabel->
  "In[191]:=",ExpressionUUID->"7d89df48-a087-5941-b4cd-d62ffbd83fe7"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Time marching", "Subsection",
 CellChangeTimes->{{3.990851936232027*^9, 
  3.9908519382138786`*^9}},ExpressionUUID->"352d23d2-b88e-034e-a685-\
6cd82fab305b"],

Cell[TextData[{
 "We\[CloseCurlyQuote]ll use ",
 StyleBox["NestList",
  FontSlant->"Italic"],
 " to build each time step iteratively using ",
 StyleBox["stepBurgers ",
  FontSlant->"Italic"],
 "as the function we\[CloseCurlyQuote]re applying, with ",
 StyleBox["initU",
  FontSlant->"Italic"],
 " as the initial conditions and ",
 StyleBox["instants",
  FontSlant->"Italic"],
 " the total number of timesteps."
}], "Text",
 CellChangeTimes->{{3.990851952581148*^9, 
  3.9908520720368805`*^9}},ExpressionUUID->"317606d8-6df8-9f4c-9c11-\
04fdccd90e14"],

Cell[BoxData[
 RowBox[{
  RowBox[{"sol", " ", "=", " ", 
   RowBox[{"NestList", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"stepBurgers", "[", 
       RowBox[{"#", ",", " ", "\[Nu]", ",", " ", "dt", ",", " ", "dx"}], 
       "]"}], "&"}], ",", " ", "initU", ",", " ", "instants"}], "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.990852086136917*^9, 3.990852115356781*^9}},
 CellLabel->
  "In[192]:=",ExpressionUUID->"91dab91d-b568-304f-9a30-09a11e0603d9"],

Cell[TextData[{
 "The way we\[CloseCurlyQuote]ve structured our lists, we have ",
 StyleBox["sol[[1, All]] ",
  FontSlant->"Italic"],
 "representing the solution at all 256 points of the 1D grid at the first \
instant, and ",
 StyleBox["sol[[instants+1, All]] ",
  FontSlant->"Italic"],
 "representing the solution at all 256 points of the 1D grid at the last \
instant of the simulation."
}], "Text",
 CellChangeTimes->{{3.99085228891572*^9, 3.990852355584345*^9}, {
  3.990852426703451*^9, 
  3.9908524701110954`*^9}},ExpressionUUID->"767b1289-4f90-f84e-9e48-\
40e983495ab7"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"sol", "[", 
   RowBox[{"[", 
    RowBox[{"1", ",", " ", "All"}], "]"}], "]"}], "==", "initU"}]], "Input",
 CellChangeTimes->{{3.990852231245693*^9, 3.990852271163061*^9}, {
  3.990852384858309*^9, 3.9908524345468693`*^9}, {3.9908524786704426`*^9, 
  3.990852482287792*^9}},
 CellLabel->
  "In[225]:=",ExpressionUUID->"131f804c-ffa1-d242-9fc7-c7dbaa8eec70"],

Cell[BoxData["True"], "Output",
 CellChangeTimes->{{3.9908522352308865`*^9, 3.990852271642542*^9}, {
   3.990852387014971*^9, 3.9908524352233067`*^9}, 3.990852482750971*^9},
 CellLabel->
  "Out[225]=",ExpressionUUID->"1c8502ee-eaf8-7f4c-88c2-827ca103c790"]
}, Open  ]],

Cell[TextData[{
 "Likewise, ",
 StyleBox["sol[[All, 42]]",
  FontSlant->"Italic"],
 " represents the position of 42nd point of the grid at all timesteps. "
}], "Text",
 CellChangeTimes->{{3.9908526015141506`*^9, 3.9908526335916424`*^9}, {
  3.9908526768220177`*^9, 
  3.990852702340082*^9}},ExpressionUUID->"19c397de-e1e1-3549-a914-\
07f0dcbdc584"],

Cell["Now, let\[CloseCurlyQuote]s look at the results!", "Text",
 CellChangeTimes->{{3.9908525006840916`*^9, 
  3.990852506921257*^9}},ExpressionUUID->"4276e259-0954-654b-bade-\
e84e98fd2025"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Results", "Section",
 CellChangeTimes->{{3.99085251497793*^9, 
  3.990852516351639*^9}},ExpressionUUID->"17825269-4a03-b54f-88b7-\
3bcbe794b454"],

Cell["\<\
Snapshots of the numerical solution at t = 0, 0.5, 1 and 2. The initial sine \
smooths and its amplitude decays monotonically: exactly what is expected in \
this diffusion dominated regime (here \[Nu]=0.5).\
\>", "Text",
 CellChangeTimes->{{3.990852523320469*^9, 
  3.990852551589119*^9}},ExpressionUUID->"fc3d9fff-4fb7-4545-b7ef-\
a3f2a2bf64db"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"GraphicsRow", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"Table", "[", "\n", "    ", 
    RowBox[{
     RowBox[{"ListLinePlot", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Transpose", "@", 
        RowBox[{"{", 
         RowBox[{"xCoords", ",", " ", 
          RowBox[{"sol", "[", 
           RowBox[{"[", 
            RowBox[{
             RowBox[{"Floor", "[", 
              RowBox[{"t", "/", "dt"}], "]"}], " ", "+", " ", "1"}], "]"}], 
           "]"}]}], "}"}]}], ",", 
       RowBox[{"PlotLabel", " ", "->", " ", 
        RowBox[{"\"\<t = \>\"", " ", "<>", " ", 
         RowBox[{"ToString", "[", "t", "]"}]}]}], ",", "\[IndentingNewLine]", 
       RowBox[{"PlotRange", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "1.2"}], ",", " ", "1.2"}], "}"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"Frame", " ", "->", " ", "True"}]}], "]"}], ",", "\n", "    ", 
     RowBox[{"{", 
      RowBox[{"t", ",", " ", 
       RowBox[{"{", 
        RowBox[{"0", ",", " ", "0.5", ",", " ", "1.0", ",", " ", "2.0"}], 
        "}"}]}], "}"}]}], "]"}], ",", "\[IndentingNewLine]", 
   RowBox[{"ImageSize", " ", "->", " ", "800"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.9908525606147957`*^9, 3.9908525606147957`*^9}, {
  3.9908527289068737`*^9, 3.9908528400555897`*^9}, {3.9908528708606663`*^9, 
  3.9908529106755104`*^9}},
