Cell["\<\
The exact solution is an infinite series truncated at nMax modes. The plot \
(shown at \[Nu] = 0.4) compares nMax = 1, 2, 3, 10, 20. A single mode is \
hopeless at early times, when the profile is steepest and richest in high \
harmonics, but the series converges fast: a handful of modes already coincide \
visually, and fewer are needed at later times once diffusion has erased the \
fine structure.\
\>", "Text",ExpressionUUID->"302d84c5-6a32-834e-b9de-4768774db1fd"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"GraphicsRow", "[", 
  RowBox[{
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"Evaluate", "@", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"solExacteBurgers", "[", 
           RowBox[{"x", ",", " ", "t", ",", " ", "0.4", ",", " ", "n"}], 
           "]"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"n", ",", " ", 
            RowBox[{"{", 
             RowBox[{
             "1", ",", " ", "2", ",", " ", "3", ",", " ", "10", ",", " ", 
              "20"}], "}"}]}], "}"}]}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", " ", "0", ",", " ", 
         RowBox[{"2", " ", "Pi"}]}], "}"}], ",", 
       InterpretationBox[
        DynamicModuleBox[{Typeset`open = False}, 
         TemplateBox[{"Expression", "SequenceIcon", 
