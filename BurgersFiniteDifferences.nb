Cell[TextData[{
 "The substitution ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["u", "TI"], "\[LongEqual]", "-2", "\[Nu]", 
         FractionBox["\[PartialD]", 
          RowBox[{"\[PartialD]", 
            StyleBox["x", "TI"]}]], 
         RowBox[{"(", 
           RowBox[{"log", "\[Phi]"}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "u = -2\\nu\\frac{\\partial}{\\partial x}(\\log \\phi)", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f4cbd557-7b87-0142-9304-8b520845f2af"],
 " turns the nonlinear Burgers equation into the linear heat equation ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox[
          RowBox[{"\[PartialD]", "\[Phi]"}], 
          RowBox[{"\[PartialD]", 
            StyleBox["t", "TI"]}]], "\[LongEqual]", 
         FractionBox[
          RowBox[{
            SuperscriptBox["\[PartialD]", "2"], "\[Phi]"}], 
          RowBox[{"\[PartialD]", 
            SuperscriptBox[
             StyleBox["x", "TI"], "2"]}]]}], TraditionalForm], "errors" -> {},
      "input" -> 
     "\\frac{\\partial \\phi}{\\partial t} = \\frac{\\partial^2 \
\\phi}{\\partial x^2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b24998f8-d413-7a4e-901a-28d971c2f4ca"],
 ". For ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["u", "TI"], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["x", "TI"], ",", "0"}], ")"}], "\[LongEqual]", "sin", 
         RowBox[{"(", 
           StyleBox["x", "TI"], ")"}]}], TraditionalForm], "errors" -> {}, 
     "input" -> "u(x,0) = \\sin (x) ", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "075e3318-4f48-3b43-81f0-e06235a83faf"],
 " the matching heat-equation data is ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Phi]", 
         RowBox[{"(", 
           RowBox[{
             StyleBox["x", "TI"], ",", "0"}], ")"}], "\[LongEqual]", "exp", 
         RowBox[{"(", 
           FractionBox[
            RowBox[{"cos", "(", 
              StyleBox["x", "TI"], ")"}], 
            RowBox[{"2", "\[Nu]"}]], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\phi (x,0) = \\exp (\\frac{\\cos (x)}{2\\nu})", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "34e01575-3a72-b446-bd74-1f6ef5bafef5"],
 ". Expanding this with the generating function of the modified Bessel \
functions gives Fourier coefficients ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["I", "TI"], 
          StyleBox["n", "TI"]], "(", 
         FractionBox["1", 
          RowBox[{"2", "\[Nu]"}]], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "I_n(\\frac{1}{2\\nu})", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "adc8d3e7-0765-d647-9c32-7d9545e95f2b"],
 ", each mode then decays as ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"exp", "(", 
         RowBox[{"-", 
           SuperscriptBox[
            StyleBox["n", "TI"], "2"], "\[Nu]", 
           StyleBox["t", "TI"]}], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\exp(-n^2 \\nu t)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ef4fbaed-d8d9-434d-96c9-a7c7c9f275c1"],
 ". Reconstructing ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["u", "TI"], TraditionalForm], "errors" -> {}, "input" -> "u ",
      "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "0aa474d7-4983-ce4b-a7d5-f99ce4d21d77"],
 " from ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[Phi]", TraditionalForm], "errors" -> {}, "input" -> 
     "\\phi ", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9eff35ef-f045-e94b-8b1b-5227266cd0b2"],
 " yields the reference solution below."
}], "Text",
 CellChangeTimes->{{3.9908529900413685`*^9, 3.9908531007471085`*^9}, {
  3.9908534852619724`*^9, 
  3.990853592541546*^9}},ExpressionUUID->"bc9d2c30-809c-de4c-bfbc-\
c85f0096e378"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"solExacteBurgers", "[", 
    RowBox[{"x_", ",", " ", "t_", ",", " ", "\[Nu]_", ",", " ", 
     RowBox[{"nMax_", ":", "20"}]}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"\[Phi]", ",", " ", "d\[Phi]", ",", " ", "a"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"a", "[", "n_", "]"}], ":=", 
       RowBox[{"BesselI", "[", 
        RowBox[{"n", ",", " ", 
         FractionBox["1", 
          RowBox[{"2", "\[Nu]"}]]}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"\[Phi]", " ", "=", " ", 
       RowBox[{"Sum", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"a", "[", "n", "]"}], "*", 
          RowBox[{"Exp", "[", 
           RowBox[{
            RowBox[{"-", 
             SuperscriptBox["n", "2"]}], "*", "\[Nu]", "*", "t"}], "]"}], "*", 
          RowBox[{"Exp", "[", 
           RowBox[{"I", "*", "n", "*", "x"}], "]"}]}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"n", ",", " ", 
           RowBox[{"-", "nMax"}], ",", " ", "nMax"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"d\[Phi]", " ", "=", " ", 
       RowBox[{"Sum", "[", 
        RowBox[{
         RowBox[{"I", "*", "n", "*", 
          RowBox[{"a", "[", "n", "]"}], "*", 
          RowBox[{"Exp", "[", 
           RowBox[{
            RowBox[{"-", 
             SuperscriptBox["n", "2"]}], "*", "\[Nu]", "*", "t"}], "]"}], "*", 
          RowBox[{"Exp", "[", 
           RowBox[{"I", "*", "n", "*", "x"}], "]"}]}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"n", ",", " ", 
           RowBox[{"-", "nMax"}], ",", " ", "nMax"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Re", "[", 
       RowBox[{"-", 
        RowBox[{"(", 
         RowBox[{"2", "\[Nu]", 
          FractionBox["d\[Phi]", "\[Phi]"]}], ")"}]}], "]"}]}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9908536377890205`*^9, 3.990853849447201*^9}},
 CellLabel->
  "In[236]:=",ExpressionUUID->"3846a779-179d-174b-a876-0ef7b7cf97b2"],

Cell["\<\
Subtracting the exact solution from the numerical one gives the pointwise \
error. It stays at the order of and below across the domain and shrinks in \
time as the solution smooths.\
\>", "Text",
 CellChangeTimes->{{3.990853894732052*^9, 
  3.990853907809433*^9}},ExpressionUUID->"49493248-582a-d54c-bd03-\
816ab88de939"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"GraphicsRow", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Table", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"ListLinePlot", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Transpose", "@", 
        RowBox[{"{", 
         RowBox[{"xCoords", ",", 
          RowBox[{
           RowBox[{"sol", "[", 
            RowBox[{"[", 
             RowBox[{
              RowBox[{"Floor", "[", 
               RowBox[{"t", "/", "dt"}], "]"}], " ", "+", " ", "1"}], "]"}], 
            "]"}], " ", "-", " ", 
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{"solExacteBurgers", "[", 
              RowBox[{"x", ",", " ", "t", ",", " ", "\[Nu]"}], "]"}], ",", 
             " ", 
             RowBox[{"{", 
              RowBox[{"x", ",", " ", "xCoords"}], "}"}]}], "]"}]}]}], "}"}]}],
        ",", 
       InterpretationBox[
        DynamicModuleBox[{Typeset`open = False}, 
         TemplateBox[{"Expression", "SequenceIcon", 
           GridBox[{{
              RowBox[{
                TagBox["\"Head: \"", "IconizedLabel"], "\[InvisibleSpace]", 
                TagBox["Sequence", "IconizedItem"]}]}, {
              RowBox[{
                TagBox["\"Length: \"", "IconizedLabel"], "\[InvisibleSpace]", 
                TagBox["5", "IconizedItem"]}]}, {
              RowBox[{
                TagBox["\"Byte count: \"", "IconizedLabel"], 
                "\[InvisibleSpace]", 
                TagBox["616", "IconizedItem"]}]}}, 
            GridBoxAlignment -> {"Columns" -> {{Left}}}, DefaultBaseStyle -> 
            "Column", 
            GridBoxItemSize -> {
             "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], 
           Dynamic[Typeset`open]},
          "IconizedObject"]],
        Sequence[
        PlotStyle -> Blue, PlotRange -> All, Frame -> True, PlotLabel -> 
         "t = " <> ToString[$CellContext`t], FrameLabel -> {"x", "erreur"}],
        SelectWithContents->True,
        Selectable->False]}], "]"}], ",", 
     RowBox[{"{", 
